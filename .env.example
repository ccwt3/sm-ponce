# Copia este archivo a `.env.local` y rellena los valores reales.
# Las variables NEXT_PUBLIC_* se exponen al navegador; no pongas secretos en ellas.

# --- Supabase (producción / proyecto remoto) ---
NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Clave de servicio (solo servidor). NUNCA la expongas con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# UUID del usuario usado por el script de seed (scripts/seed-products.ts). Opcional.
SEED_USER_ID=

# --- Supabase (desarrollo local con `supabase start`) ---
NEXT_PUBLIC_SUPABASE_URL_DEV=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_KEY_DEV=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# --- PostHog (analytics / session replay / error tracking) ---
# Token del proyecto (Project Settings → Project API Key). Es público por diseño.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_xxxxxxxxxxxxxxxxxxxxxx
# Host de ingesta. US: https://us.i.posthog.com  ·  EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
